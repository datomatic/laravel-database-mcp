{
    "name": "datomatic/laravel-database-mcp",
    "description": "Read-only MCP server to let AI assistants safely explore and query a Laravel application's database.",
    "keywords": ["laravel", "mcp", "database", "ai", "claude"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/mcp": "^0.8"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pao": "^1.1",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Datomatic\\LaravelDatabaseMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Datomatic\\LaravelDatabaseMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Datomatic\\LaravelDatabaseMcp\\LaravelDatabaseMcpServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process",
        "rector:dry": "vendor/bin/rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
