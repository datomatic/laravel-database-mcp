{
    "name": "datomatic/laravel-database-mcp",
    "description": "Read-only MCP server to let AI assistants safely explore and query a Laravel application's database.",
    "keywords": ["laravel", "mcp", "database", "ai", "claude"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/mcp": "^0.8"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Datomatic\\LaravelDatabaseMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Datomatic\\LaravelDatabaseMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Datomatic\\LaravelDatabaseMcp\\LaravelDatabaseMcpServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
